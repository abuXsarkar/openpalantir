# OpenPalantir Environment Configuration

# Data Source Mode
# Set to 'true' for demo/development with mock data
# Set to 'false' for live API data
USE_MOCK_DATA=true

# NASA FIRMS API Key (optional in mock mode)
# Get your free key at: https://firms.modaps.eosdis.nasa.gov/api/area/
NASA_FIRMS_API_KEY=your_api_key_here

# Database (automatically configured in Docker)
DATABASE_URL=postgresql://geoint:geoint_dev@postgres:5432/geoint
